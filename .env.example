# Database
DATABASE_URI=mysql+pymysql://username:password@host:3306/database_name

# Flask
SECRET_KEY=change-me-to-a-random-secret
FLASK_ENV=development
LOG_LEVEL=INFO
LOG_DIR=logs

# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=you@example.com
SMTP_PASSWORD=app-password
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_DEBUG=0
MAIL_DEFAULT_SENDER=you@example.com
ENABLE_MAILER=False
SMTP_TIMEOUT=10
